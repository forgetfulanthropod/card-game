// Database
{
    "compilerOptions": {
        "module": "commonjs",
        "noEmit": true,
        "strict": true,
        "target": "es2017",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "paths": {
            "@/*": ["./*"]
        }
    }
}
