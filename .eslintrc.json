{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 12,
        "sourceType": "module"
        // ,"project": "server/tsconfig.json"
    },
    "plugins": [
        "@typescript-eslint",
        "unused-imports",
        "simple-import-sort"
    ],
    "rules": {
        // "@typescript-eslint/no-use-before-define": [ "warn", { "functions": false, "classes": false, "variables": true } ],
        // auto-fixable stuff for formatter:
        "quotes": [
            "warn",
            "single"
        ],
        "no-unused-expressions": "warn",
        "consistent-return": "warn",
        "no-useless-return": "warn",
        "@typescript-eslint/ban-ts-comment": "off",
        "@typescript-eslint/no-empty-function": "off",
        "no-debugger": "warn",
        "eqeqeq": [
            "warn",
            "always",
            {
                "null": "ignore"
            }
        ],
        // "@typescript-eslint/no-unused-vars": [ "warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^h$|^_" } ],
        // for import organizing:
        // "sort-imports": [
        //     "warn"
        // ],
        "@typescript-eslint/consistent-type-imports": [
            "warn",
            {
                "prefer": "type-imports"
            }
        ],
        "@typescript-eslint/no-unused-vars": "off",
        "unused-imports/no-unused-imports": "warn",
        "unused-imports/no-unused-vars": [
            "warn",
            {
                "vars": "all",
                "varsIgnorePattern": "^h$|^_",
                "args": "after-used",
                "argsIgnorePattern": "^_"
            }
        ],
        "simple-import-sort/imports": "error",
        // "simple-import-sort/exports": "error",
        "no-multiple-empty-lines": "warn",
        "padding-line-between-statements": [
            "warn",
            {
                "blankLine": "always",
                "prev": "*",
                "next": "function"
            }
            // ,{ "blankLine": "always", "prev": "*", "next": "export" }
        ],
        "@typescript-eslint/await-thenable": "error",
        "@typescript-eslint/require-await": "error",
        "@typescript-eslint/no-floating-promises": "error",
        "array-bracket-newline": [
            "warn",
            {
                "multiline": true
            }
        ],
        "array-element-newline": [
            "warn",
            "consistent"
        ],
        "comma-dangle": [
            "warn",
            {
                "arrays": "always-multiline",
                "objects": "always-multiline",
                "imports": "always-multiline",
                "exports": "always-multiline",
                "functions": "only-multiline"
            }
        ]
    },
    "ignorePatterns": [
        "scripts/",
        "server/lib",
        "build",
        "tests",
        "**/*.js"
    ],
    // ,"overrides": [ { "files": [ "client/**/*.ts", "client/**/*.tsx", "client/**/*.d.ts", "shared/**/*.ts", "functions/**/*.ts" ] } ]
    "overrides": [
        {
            "files": [
                "client/**/*.ts",
                "client/**/*.tsx",
                "client/**/*.d.ts",
                "shared/**/*.ts"
            ],
            "extends": [
                "plugin:react/recommended"
            ],
            "plugins": [
                "react",
                "react-hooks"
            ],
            "parserOptions": {
                "ecmaFeatures": {
                    "jsx": true
                },
                "project": "tsconfig.json"
            },
            "rules": {
                "react/no-unused-prop-types": "warn",
                "react/jsx-props-no-multi-spaces": "warn",
                "react/no-unknown-property": [
                    "warn",
                    {
                        "ignore": [
                            "class"
                        ]
                    }
                ],
                "react/jsx-tag-spacing": [
                    "warn",
                    {
                        "beforeClosing": "never"
                    }
                ],
                "react-hooks/rules-of-hooks": [
                    "error"
                    // ,{
                    //     "additionalHooks": "(useEventEmitter|useSubscription|useEffectWhen)"
                    // }
                ],
                "react-hooks/exhaustive-deps": [
                    "warn"
                    // ,{
                    //     "additionalHooks": "(useEffectWhen)"
                    // }
                ],
                "react/react-in-jsx-scope": "off"
            },
            "settings": {
                "react": {
                    "version": "17.0.2"
                }
            }
        },
        {
            "files": [
                "server/**/*.ts"
            ],
            "parserOptions": {
                "project": "./server/tsconfig.json"
            }
        }
    ]
}
