+++ b/server/auth/util.ts
@@ -0,0 +1,4 @@
+const usernamePattern = /^([A-Z]|[a-z]|-){3,25}$/
+export function isValidUsername(username: string): boolean {
+    return usernamePattern.test(username)
+}
