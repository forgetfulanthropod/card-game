+import { h } from 'preact'
+import { useCallback, useRef } from 'preact/hooks'
+
+import { startAimGame } from './script'
+import s from './style.module.css'
+
+export default function AimGame(): JSX.Element {
+    // const ref = useRef<HtmlSection>(null)
+    const started = useRef(false)
+    const onRef = useCallback((node: HTMLElement | null) => {
+        if (node != null) {
+            setTimeout(() => {
+                if (!started.current) {
+                    started.current = true
+                    startAimGame()
+                }
+            }, 1000)
+        }
+    }, [])
+    return (
+        <section class={s['game']} ref={onRef}>
+            <div class={s['gameInner'] + ' ' + s['container']}>
+                <div class={s['screen']}>
+                    <h1 class={s['screenHeadline']}>Aim Training</h1>
+                    <h3 class={s['screenSubheading']}>
+                        <span class={s['warn']}>Attention! </span>If you don't hit the ball, you will lose
+                    </h3>
+                    <button class={s['screenStart']}>Start</button>
+                </div>
+                <div class={s['screen']}>
+                    <h1 class={s['screenHeadline']}>Choise time</h1>
+                    <ul class={s['timeList']}>
+                        <li class={s['timeItem']}>
+                            <button class={s['timeBtn']} data-time="10">
+                                10 Sec
+                            </button>
+                        </li>
+                        <li class={s['timeItem']}>
+                            <button class={s['timeBtn']} data-time="20">
+                                20 Sec
+                            </button>
+                        </li>
+                        <li class={s['timeItem']}>
+                            <button class={s['timeBtn']} data-time="30">
+                                30 Sec
+                            </button>
+                        </li>
+                        <li class={s['timeItem field']}>
+                            <input class={s['timeField']} type="number" placeholder="Another... (In seconds)" />
+                            <button class={s['timeFieldBtn']} type="submit"></button>
+                        </li>
+                    </ul>
+                </div>
+                <div class={s['screen']}>
+                    <h3 class={s['screenTitle']}>
+                        Time left &nbsp
+                        <span class={s['screenTimer']}>00:00</span>
+                    </h3>
+                    <div class={s['screenBoard']}> </div>
+                    <div class={s['gameOver'] + s['hide']}>
+                        <button class={s['gameOverRestart']}>Restart</button>
+                    </div>
+                </div>
+            </div>
+        </section>
+    )
+}
