+import { h } from 'preact'
+import root from 'react-shadow'
+// import styles from './shadow.css'
+
+const html = `
+    <button id="reset" onclick="init()">Reset</button>
+    <div id="win"></div>
+    <div id="wrap"></div>
+    <!-- <audio id="fail" src="https://dl.dropbox.com/u/995571/error.wav"></audio> -->
+    <audio id="fail" src="https://www.soundjay.com/buttons/beep-01a.wav"></audio>
+`
+const js = `
+  /*Developed By Yash Bhardwaj*/
+  console.log('log from the shadow')
+//   debugger
+  var $segs;
+  var angle = 0;
+  var segments = 36;
+  var rings = 4;
+  var cnt;
+  var i;
+  var error_snd;
+  var angle = Array(rings);
+  var angleSpeed = Array(rings);
+  var done = false;
+
+  function setupSegments() {
+    var wrap = document.getElementById("wrap");
+    var scale = 1.3;
+    var opac = 0.5;
+    angleSpeed[0] = 3.0;
+    angleSpeed[1] = -3.0;
+    angleSpeed[2] = 2.5;
+    angleSpeed[3] = -2.5;
+    for (var r = 0; r < rings; r++) {
+      angle[r] = 0;
+      var ring = document.createElement("div");
+      ring.className = "ring";
+      var hide = false;
+      for (var s = 0; s < segments; s++) {
+        var segment = document.createElement("div");
+        var cn = "seg";
+        var change_p = hide ? 0.5 : 0.3;
+        if (Math.random(1.0) < change_p) hide = !hide;
+        if (hide) cn += " hide";
+        if (Math.random(1.0) < 0.1) cn += " long";
+        segment.className = cn;
+        segment.title = ring;
+        // debugger
+        ring.insertBefore(segment, null);
+      }
+      $(ring).css("transform", "scale(" + scale + ")");
+      ring.style.opacity = opac;
+      opac += 0.15;
+      scale *= 0.7;
+      debugger
+      wrap.insertBefore(ring, null);
+    }
+  }
+
+  function rep_ex() {
+    for (var j = 0; j < rings; j++) {
+      angle[j] += angleSpeed[j];
+      if (angle[j] >= 360) angle[j] -= 360;
+    }
+    cnt = 0;
+    $(".seg").each(function () {
+      var index = Math.floor(cnt / segments);
+      var a = angle[index] + (360 / segments) * cnt;
+      $(this).css("transform", "rotate(" + a + "deg)");
+      cnt++;
+    });
+    var a = (Math.PI * angle[0]) / 45.0;
+    a = Math.sin(a) / 4 + 0.8;
+    $("#win").css("transform", "scale(" + a + ")");
+  }
+
+  function init() {
+    $("#wrap").html("");
+    $("#reset").css("display", "none");
+    $("#win").mouseenter(function () {
+      fail(false);
+    });
+    setupSegments();
+    error_snd = document.getElementById("fail");
+    $(".seg").each(function () {
+      $(this).css("transform-origin", "50% 200px");
+      $(this).mouseenter(function () {
+        fail(true);
+      });
+    });
+    i = setInterval(rep_ex, 30);
+    done = false;
+  }
+
+  function fail(play) {
+    if (done) return;
+    window.clearTimeout(i);
+    if (play) error_snd.play();
+    else alert("You Win");
+    $("#reset").css("display", "block");
+    done = true;
+  }
+
+  $(document).ready(init);
+`
+const css = `
+  body {
+    background-color: #000000;
+  }
+  .ring {
+    position: absolute;
+    left: 300px;
+    top: 100px;
+    transform-origin: 18px 200px;
+    -webkit-transform-origin: 18px 200px;
+  }
+  .seg {
+    position: absolute;
+    width: 36px;
+    height: 20px;
+    background-color: #00cc00;
+  }
+  .hide {
+    display: none;
+  }
+  .long {
+    height: 60px;
+  }
+  #win {
+    position: absolute;
+    left: 298px;
+    top: 280px;
+    width: 20px;
+    height: 20px;
+    border: 10px solid #ffaa00;
+    background-color: #ffffff;
+    box-shadow: 0 0 10px 10px rgba(255, 0, 0, 1);
+    border-radius: 50%;
+  }
+</style>
+`
+export default function Hacking(): JSX.Element {
+    // const doc = useR
+    return (
+        <root.div>
+            <div ref={onDivRef}></div>
+            <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js"></script>
+            <style type="text/css">{css}</style>
+            {/* <script ref={onScriptRef}></script> */}
+        </root.div>
+    )
+}
+
+async function onDivRef(node: HTMLDivElement | null) {
+    if (node == null) return
+    // node.appendChild(document.createTextNode())
+    node.innerHTML = html
+    // const jqUrl = 'https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js'
+    // const jqScript = node.ownerDocument.createElement('script')
+    // jqScript.src = jqUrl
+    await addRemoteScript('https://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js', node)
+    // const script = node.ownerDocument.createElement('script')
+    const script = node.getRootNode().createElement('script')
+    script.textContent = js
+    node.appendChild(script)
+}
+
+async function addRemoteScript(url: string, node: HTMLElement) {
+    // debugger
+    const response = await fetch(url)
+    if (!response.ok) {
+        return
+    }
+    const text = await response.text()
+    // debugger
+    // const sc = node.ownerDocument.createElement('script')
+    const sc = node.getRootNode().createElement('script')
+    sc.textContent = text
+    node.appendChild(sc)
+}
+
+// function onScriptRef(node: HTMLScriptElement | null) {
+//     if (node == null) return
+
+// }
