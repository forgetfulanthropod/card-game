// Server
{
    "compilerOptions": {
        "composite": true,
        "module": "esnext",
        "moduleResolution": "node",
        "incremental": true,
        "strict": true,
        "target": "es2017",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "declaration": true,
        // "emitDeclarationOnly": true,
        // "outFile": "./dist/index.js",
        "outDir": "./dist",
        // "rootDir": ".",
        "paths": {
            "@serverActions": ["./actions/types/serverActions"],
            "@/*": ["./*"]
        }
    },
    "compileOnSave": true,
    // "files": ["index.ts"],
    "include": ["./**/*.ts"],
    "exclude": ["dist", "node_modules"],
    "references": [
        {
            "path": "../shared"
        }
    ]
}
