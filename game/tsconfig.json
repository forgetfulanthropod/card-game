// Server
{
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node",
        "incremental": true,
        "strict": true,
        "target": "es2017",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "declaration": true,
        // "emitDeclarationOnly": true,
        // "outFile": "./dist/index.js",
        "outDir": "./dist",
        "paths": {
            "@serverActions": ["./actions/types/serverActions"],
            "@shared": ["../shared/index"],
            "@shared/code": ["../shared/code/index"],
            "@/*": ["./*"]
        }
    },
    "compileOnSave": true,
    "include": ["./**/*.ts", "../shared"],
    "exclude": ["dist", "node_modules"]
}
