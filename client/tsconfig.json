// Client
{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "lib": ["dom", "dom.iterable", "esnext"],
        // "types": [""],
        "jsx": "react-jsx",
        "paths": {
            "shared": ["../shared"],
            "shared/code": ["../shared/code"],
            "@/*": ["./*"],
            "@sharedElements": ["./scenes/shared"],
        }
    },
    "references": [{ "path": "../shared" }],
    "include": [
        "*",
        "**/*",
        "**/*.json",
        "**/*.tsx",
        "**/*.js",
        "**/*.ts"
    ]
}
