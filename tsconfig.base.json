// Base
{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "incremental": true,
        "strict": true,
        "composite": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "lib": ["esnext"],
        "isolatedModules": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "experimentalDecorators": true,
        "rootDir": ".",
        "outDir": "./builds/tsc/"
    },
    "exclude": ["node_modules", "**/node_modules/*"]
}
