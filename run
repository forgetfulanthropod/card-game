#!/bin/bash

set -euo pipefail # strict mode

# Add npm binaries to path
export PATH=./node_modules/.bin:$PATH

# === LOCAL DEV BUILD HACKS / NOTES ===
# - `bash run dev` (or `npm run dev`): one-line clean local dev. Does full client+server build then serves at :3456.
#   No crypto/wallet, uses simple username accounts (4 max) in server/data/simple-db.json .
# - Styles: tailwind CLI build (client:styles / styles:build) to public/styles.css because esbuild css plugins crash in env.
#   See scripts/clientEsbuild.mjs header for details. global.css import commented out.
# - Watch: limited; client:build-watch exists but stripped in esbuild for compat. Re-run dev or builds to iterate.
# - Server runs with DEV_STATIC_ASSETS to serve public/ directly from built server.
# - To clean rebuild: rm -rf builds public/dailyship.js public/styles.css ; npm run dev
# - Account limit + username + overwrite/delete supported in storage + UI.

# declare -a validCommands

## ROOT

function install-all() {
    pnpm i
}

function CI() {
    set +e
    source ~/.bashrc
    pnpm i -P
    IS_PRODUCTION=true pnpm run client:build
    IS_PRODUCTION=true pnpm run server:build
}

function lint() {
    eslint . --cache
}

function clean-tsc-all() {
    rm -rf **/dist **/tsconfig.tsbuildinfo
    tsc-all
}

function tsc-all() {
    tsc -b .
}

function build-all() {
    node scripts/buildAll.mjs
}

function fmt() {
    generate-indices
    prettier-no-jsx-parens -w -l .
    eslint . --fix --cache
}

# sorts the directories in the project by the number of files in each
function biggest-dirs() {
    set +x
    fd -t d | while read -r line; do echo $(ls "$line" | wc -l) $line; done | sort -n
}

function mp4-to-webm() {
    path=$1
    ffmpeg -i $1.mp4 -c:v libvpx-vp9 -crf 30 -b:v 0 -b:a 128k -c:a libopus $1.webm
}

function png-to-webp() {
    path=$1
    mogrify -format webp $1.png

    # alternate
    # parallel -eta cwebp {} -o {.}.webp ::: *.png

    # https://developers.google.com/speed/webp/docs/cwebp
    # https://savannah.gnu.org/projects/parallel/
}

