#!/bin/bash

set -e # fail on error

# Add npm binaries to path
export PATH=./node_modules/.bin:$PATH

# declare -a validCommands

## ROOT

function install-all() {
    set +x # skip printing in this function
    wd=$(pwd)
    for d in . client server db crypto-server; do
        cd $d
        echo "installing in $d"
        pnpm install &
        cd $wd
    done
    set -x
}

function CI() {
    bash scripts/ci.sh
}

function lint() {
    eslint . --cache
}

function tsc-all() {
    client:tsc &
    server:tsc &
    db:tsc &
    crypto:tsc &
}

function build-all() {
    client:build &
    server:build &
    db:build &
    crypto:build &
}

function clean-builds() {
    rm -rf builds
    rm -f db/db-build.js
}

function fmt() {
    prettier-no-jsx-parens -w -l .
    eslint . --fix --cache
}

# function fmt() {
#     pprettier --write \"**/*.{ts,tsx,json,css,mjs,js}\"
#     eslint . --fix
# }

function self-fmt() {
    ~/go/bin/shfmt -l -w -i 4 ./run
}

function generate-indices() {
    vscode-generate-index-standalone ./shared/**/*.ts ./client/**/*.ts ./server/**/*.ts !node_modules
    vscode-generate-index-standalone ./server/**/**/*.ts !node_modules
}

function save-staged() {
    bash scripts/savestaged.sh
}

function new-todo() {
    git diff origin/main -G TODO
}

function clean-branches() {
    git branch -D $(git branch | grep -v 'main')
    git fetch
    git pull
    git remote prune origin
}

function lint-watch() {
    echo 'doesnt work great'
    esw -w server/**/*.ts client/**/*.ts{,x} shared/**/*.ts
}

function view-imports-exports() {
    ag --nonumbers --only-matching --group 'import.*$|(export [A-z]+ [A-z]+)' . >imports-and-exports.ignore.txt
}

function arkit() {
    npx arkit
}

function dep-graph() {
    rm -f deps.svg
    depcruise --output-type=dot --ts-config=tsconfig.json **/*.ts --exclude node_modules | dot -T svg >deps.svg
    open deps.svg
}

function npm-clean() {
    # previously: /{pnpm-lock.yaml,node_modules}
    rm -rf {.,client,server,crypto-server,db}/{node_modules}
}

## CLIENT

function client:build() {
    node scripts/clientEsbuild.mjs
}
function client:build-watch() {
    node scripts/clientEsbuild.mjs watch
}
function client:bare-build-watch() {
    BARE=yes client:build-watch
}
function client:tsc() {
    tsc --project client/tsconfig.json
}
function client:live-serve() {
    live-server builds/client --host=localhost --port=3000
}

## MAIN SERVER

function server:server() {
    node --enable-source-maps builds/server.js
}
function server:server-watch() {
    nodemon --enable-source-maps --watch builds/server.js builds/server.js
}
function server:server-watch-debug() {
    nodemon --inspect --enable-source-maps --watch builds/server.js builds/server.js
}
function server:build() {
    node scripts/serverEsbuild.mjs
}
function server:build-watch() {
    node scripts/serverEsbuild.mjs watch
}
function server:tsc() {
    tsc --project server/tsconfig.json
}
function server:test() {
    cd server
    testyts
}

## CRYPTO SERVER

function crypto:build() {
    esbuild crypto-server/index.ts --bundle --minify --tree-shaking=true --platform=node --outfile=builds/crypto.js
}
function crypto:start() {
    rm -f builds/crypto.js && npm run build && node build.js
}
function crypto:tsc() {
    tsc --project crypto-server/tsconfig.json
}

## DATABASE

function db:build() {
    rm -f db/db-build.js && esbuild db/index.ts --platform=node --bundle --outfile=db/db-build.js
}
function db:server() {
    node --enable-source-maps db/db-build.js
}
function db:run() {
    db:build && db:server
}
function db:tsc() {
    tsc --project db/tsconfig.json
}
function db:test() {
    cd db
    testyts
}

# # Check if command is valid, i.e. in valid list; if so then execute it
# if [[ " ${validCommands[*]} " =~ " ${1} " ]]; then
#     set -x # print commands as executed
#     eval "$@"
# else
#     echo "Unknown command: $1"
# fi

set -x # print commands as executed
eval "$@"
