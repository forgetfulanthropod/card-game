}

function new-todo() {
    git diff origin/main -G TODO
}

function clean-branches() {
    git branch -D $(git branch | grep -v 'main')
    git fetch
    git pull
    git remote prune origin
}

function lint-watch() {
    echo 'doesnt work great'
    esw -w server/**/*.ts client/**/*.ts{,x} shared/**/*.ts
}

function view-imports-exports() {
    ag --nonumbers --only-matching --group 'import.*$|(export [A-z]+ [A-z]+)' . >imports-and-exports.ignore.txt
}

function exports() {
    dir=$1

    ag --ts --nogroup '^export [A-z]+ [A-z]+' $dir | sed -e 's/export /,/' | column -t -s,
}

function arkit() {
    npx arkit
}

# generate the full dependency graph
function dep-graph-full() {
    rm -f dep-graph.svg
    depcruise --output-type=dot --ts-config=tsconfig.json . --exclude node_modules |
        dot -T svg >dep-graph.svg
    open dep-graph.svg
}

# generate the dependency graph in a given subdirectory
function dep-graph() {
    subdir=$1
    dashed=${subdir//\//-}
    name="dep-graph-$dashed.svg"
    rm -f $name
    depcruise $subdir --output-type=dot --include-only="^$subdir" --exclude=node_modules |
        dot -T svg >$name
    open $name
}

function dep-graph-package() {
    package=$1
    cd $package
    rm -f dep-graph.svg
    depcruise . --output-type=dot --ts-config tsconfig.json --exclude 'node_modules|@|shared' |
        dot -T svg >dep-graph.svg
    open dep-graph.svg
}

function npm-clean() {
    rm -rf pnpm-lock.yaml node_modules **/node_modules
}

## CLIENT

function client:build() {
    client:styles
    node scripts/clientEsbuild.mjs
}

function client:styles() {
    # Build Tailwind to standalone CSS (bypasses broken esbuild style plugins in this env)
    # Uses the local bin if available
    ./node_modules/.bin/tailwindcss \
      -i ./client/components/global.css \
      -o ./public/styles.css \
      --content "./client/**/*.{ts,tsx,js,jsx}" \
      --config ./tailwind.config.js \
      --minify 2>/dev/null || \
    npx tailwindcss \
      -i ./client/components/global.css \
      -o ./public/styles.css \
      --content "./client/**/*.{ts,tsx,js,jsx}" \
      --config ./tailwind.config.js \
      --minify || echo "styles build skipped or failed (will use unstyled)"
}

# alias for clean npm script access
function styles:build() {
    client:styles
}
function client:build-watch() {
    node scripts/clientEsbuild.mjs watch
}
function client:bare-build-watch() {
    BARE=yes client:build-watch
}
function client:tsc() {
    tsc --build client
}
function client:live-serve() {
    live-server builds/client --host=localhost --port=3000
}

## GAME (no has storage only memory <3)
function game:build() {
    cd game && npm run build
}

## MAIN SERVER

function server:digitalocean() {
    node builds/server.js
}
function server:server() {
    DEV_STATIC_ASSETS=yes node --enable-source-maps builds/server.js
}
function server:server-watch() {
    DEV_STATIC_ASSETS=yes nodemon --enable-source-maps --watch builds/server.js builds/server.js
}
function server:server-watch-debug() {
    DEV_STATIC_ASSETS=yes nodemon --inspect --enable-source-maps --watch builds/server.js builds/server.js
}
function server:build() {
    node scripts/serverEsbuild.mjs
}
function server:build-watch() {
    node scripts/serverEsbuild.mjs watch
}
function server:tsc() {
    tsc -b server
}

## VERCEL DEPLOY (via CLI)
function vercel:deploy() {
    echo '=== Vercel deploy (preview) ==='
    echo 'Requires: npx vercel (or npm i -g vercel), then login.'
    echo 'This project is configured for serverless via vercel.json (express app + public assets).'
    echo 'Caveats: sockets realtime limited on Vercel serverless; file-based storage is ephemeral (no persistence across invocations).'
    echo 'Run from project dir (the one with package.json + vercel.json):'
    echo '  npx vercel login'
    echo '  npm run deploy     # or: bash run vercel:deploy'
    echo '  npm run deploy:prod'
    npx vercel
}
function vercel:prod() {
    npx vercel --prod
}

## ONE LINE LOCAL DEV (no crypto, simple accounts)
function dev() {
    set +x
    echo '=== kaiju local dev ==='
    echo 'Building client + server...'
    client:build
    server:build
    echo 'Starting server (serves UI at http://localhost:3456) ...'
    echo 'Use Ctrl-C to stop. (For rebuilds: re-run npm run dev, or use client:build / server:build + restart)'
    server:server
}

function dev:watch() {
    set +x
    echo '=== kaiju local dev:watch (limited) ==='
    echo 'Building client + server...'
    client:build
    server:build
    echo 'Starting server with nodemon (auto-restart if builds/server.js changes).'
    echo 'After editing client, manually run: npm run client:build  (or bash run client:build)'
    echo 'Server will restart on its build change. Ctrl-C to stop.'
    server:server-watch
}

## MOBILE APP WRAPPER (Capacitor - from grok code)
function mobile:build() {
    echo 'Building web assets for mobile (Capacitor Android wrapper)'
    client:build
    npx cap sync android
}

function mobile:apk() {
    mobile:build
    echo 'Building Android debug APK (requires Java/Gradle/Android SDK on your machine)...'
    (cd android && ./gradlew assembleDebug)
    echo 'APK ready at: android/app/build/outputs/apk/debug/app-debug.apk'
}

function mobile:install() {
    mobile:apk
    echo 'Flashing to Android phone (adb required, USB debug enabled on phone)...'
    adb install -r android/app/build/outputs/apk/debug/app-debug.apk || echo 'Run this on a machine with adb + phone connected: adb install -r ...apk'
}

# Mobile troubleshooting (black "LOADING..." screen)
# The black screen with LOADING... means the React/Pixi client did not mount (usually because dailyship.js failed to run or socket to localhost failed in the WebView).
# Steps:
#   1. Always do a fresh: npm run mobile:build   (this does client:build + cap sync)
#   2. npm run mobile:apk
#   3. adb install ...
#   4. To play on phone against your dev server (recommended):
#      - Run "npm run dev" on your laptop (note the IP, e.g. 192.168.1.105)
#      - Phone must be on same WiFi
#      - Before or after first launch, inject the server:
#        adb shell "am start -a android.intent.action.VIEW -d 'capacitor://localhost/index.html?server=http://192.168.1.105:3456'"
#        OR set localStorage manually via a debug bridge / WebView inspector.
#   The client now supports ?server=... and localStorage.getItem('serverHost')
#   If you still see black screen, run: adb logcat | grep -i "chromium\|console\|error" to see JS errors.

function mobile:open() {
    npx cap open android
}

