// Shared
{
    "compilerOptions": {
        "composite": true,
        "module": "esnext",
        "moduleResolution": "node",
        "incremental": true,
        "strict": true,
        // "noEmit": true,
        "target": "es2017",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "outDir": "./dist"
    },
    // "compileOnSave": true,
    // "include": ["**/*.ts"],
    // "files": ["./exports.ts"],
    "exclude": ["**/*.d.ts", "node_modules"]
}
