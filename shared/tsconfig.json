// Shared
{
    "compilerOptions": {
        "composite": true,
        "module": "esnext",
        "moduleResolution": "node",
        "incremental": true,
        // "noEmit": true,
        "strict": true,
        "target": "es2017",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "outDir": "./dist"
    },
    "compileOnSave": true,
    "exclude": ["dist", "node_modules"]
}
