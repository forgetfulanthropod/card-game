{
    "name": "kaiju-root",
    "scripts": {
        "CI": "bash scripts/ci.sh",
        "lint": "eslint .",
        "fmt": "prettier -w -l . && eslint . --fix",
        "fast-prettier": "pprettier --write \"**/*.{ts,tsx,json,css,mjs,js}\"",
        "generate-indices": "vscode-generate-index-standalone  ./shared ./client ./server/**/*.ts",
        "save-staged": "bash scripts/savestaged.sh",
        "new-todo": "git diff origin/main -G TODO",
        "clean-branches": "git branch -D $(git branch | grep -v 'main') && git fetch && git pull && git remote prune origin",
        "lint-watch": "echo 'doesnt work great' && esw -w server/**/*.ts client/**/*.ts{,x} shared/**/*.ts",
        "view-imports-exports": "ag --nonumbers --only-matching --group 'import.*$|(export [A-z]+ [A-z]+)' . > imports-and-exports.ignore.txt",
        "arkit": "npx arkit",
        "dep-graph": "rm -f deps.svg; depcruise --output-type=dot --ts-config=tsconfig.json **/*.ts --exclude node_modules | dot -T svg > deps.svg && open deps.svg",
        "npm-clean": "rm -rf {.,client,server,crypto-server}/{pnpm-lock.yaml,node_modules}"
    },
    "dependencies": {
        "baobab": "github:qpwo/baobab#more-detailed-types",
        "deep-diff": "^1.0.2",
        "esbuild": "^0.14.9",
        "esbuild-css-modules-plugin": "^2.0.9",
        "esbuild-plugin-alias": "^0.2.1",
        "express": "^4.17.2",
        "lodash": "^4.17.21"
    },
    "devDependencies": {
        "@types/deep-diff": "^1.0.1",
        "@types/express": "^4.17.13",
        "@types/lodash": "^4.14.178",
        "@types/node": "^17.0.5",
        "@typescript-eslint/eslint-plugin": "^5.8.1",
        "@typescript-eslint/parser": "^5.8.1",
        "eslint": "^8.5.0",
        "eslint-plugin-react": "^7.28.0",
        "eslint-plugin-react-hooks": "^4.3.0",
        "eslint-plugin-simple-import-sort": "^7.0.0",
        "eslint-plugin-unused-imports": "^2.0.0",
        "prettier": "^2.5.1",
        "typescript": "^4.5.4",
        "vscode-generate-index-standalone": "^1.6.0"
    }
}
