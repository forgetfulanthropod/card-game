        "tsc-watch": "tsc --watch --preserveWatchOutput",
        "savestaged": "bash scripts/savestaged.sh",
        "newtodo": "git diff origin/main -G TODO",
        "CI": "npm run clean && npm i --production && npm run build && cd server && npm i --production && npm run build"
