{
    "scripts": {
        "build": "bash scripts/build.sh",
        "start": "bash scripts/start.sh",
        "lint": "eslint -c .client.eslintrc.json $(fd -e ts -e tsx . client shared)",
        "fmt": "npm run lint -- --fix",
        "lint-actions": "eslint -c .actions.eslintrc.json $(fd -e ts . actions)",
        "fmt-actions": "npm run lint-actions -- --fix",
        "lint-all": "npm run lint && npm run lint-actions",
        "fmt-all": "npm run fmt && npm run fmt-actions",
        "tsc": "tsc",
        "tsc-watch": "tsc --watch --preserveWatchOutput",
        "serve": "live-server --quiet --port=3000 build/",
        "oldserve": "npx serve -s build -p 3000",
        "storybook": "start-storybook -p 6006",
        "build-storybook": "build-storybook",
        "fullstart": "bash scripts/fullstart.sh"
    },
    "dependencies": {
        "baobab": "^2.6.1",
        "deep-diff": "^1.0.2",
        "dotenv": "^10.0.0",
        "esbuild": "^0.13.4",
        "esbuild-css-modules-plugin": "^2.0.9",
        "esbuild-plugin-alias": "^0.2.0",
        "eventemitter3": "^4.0.7",
        "lodash": "^4.17.21",
        "pixi-webfont-loader": "^1.0.2",
        "pixi.js": "^6.1.3",
        "preact": "^10.5.14",
        "react-hot-toast": "^2.1.1",
        "socket.io-client": "^4.3.2",
        "styled-components": "^5.3.1"
    },
    "devDependencies": {
        "@types/deep-diff": "^1.0.1",
        "@types/lodash": "^4.14.175",
        "@types/node": "^16.11.2",
        "@typescript-eslint/eslint-plugin": "^4.33.0",
        "@typescript-eslint/parser": "^4.33.0",
        "eslint": "^7.32.0",
        "eslint-plugin-react": "^7.26.1",
        "eslint-plugin-react-hooks": "^4.2.0",
        "eslint-plugin-simple-import-sort": "^7.0.0",
        "eslint-plugin-unused-imports": "^1.1.5",
        "live-server": "^1.2.1",
        "typescript": "^4.4.3"
    }
}
