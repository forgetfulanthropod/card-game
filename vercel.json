{
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build",
  "functions": {
    "server/index.ts": {
      "includeFiles": ["public/**"],
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/server/index.ts" }
  ],
  "env": {
    "IS_PRODUCTION": "true",
    "NODE_ENV": "production"
  }
}