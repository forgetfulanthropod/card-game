{
  "version": 2,
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build && cp -f builds/server.js vercel-server.js",
  "functions": {
    "api/index.ts": {
      "includeFiles": "public/**",
      "excludeFiles": "builds/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api" },
    { "source": "/media-proxy(.*)", "destination": "/api" }
  ],
  "env": {
    "IS_PRODUCTION": "true",
    "NODE_ENV": "production"
  }
}