{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Four tabs",
			"dependsOn": [
				"tsc client",
				"esbuild client",
				"run server",
			],
			"dependsOrder": "parallel",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$tsc-watch"
			],
			"isBackground": true,
			"detail": "see https://stackoverflow.com/a/58181330",
			// "runOptions": { "runOn": "folderOpen", }
		},
		{
			"label": "tsc actions",
			"type": "typescript",
			"tsconfig": "actions/tsconfig.json",
			"option": "watch",
			"problemMatcher": [
				"$tsc-watch"
			],
			"group": "build",
			"presentation": {
				"group": "actions",
			}
		},
		{
			"label": "tsc client",
			"type": "typescript",
			"tsconfig": "tsconfig.json",
			"option": "watch",
			"problemMatcher": [
				"$tsc-watch"
			],
			"group": "build",
			"presentation": {
				"group": "client",
			}
		},
		{
			"label": "esbuild client",
			"type": "npm",
			"script": "start",
			"problemMatcher": [],
			"presentation": {
				"group": "client",
			}
		},
		{
			"label": "run server",
			"type": "shell",
			"command": "cd actions && npm run server-watch",
			// "script": "server",
			// "options": { "cwd": "./actions" },
			"problemMatcher": [],
			"dependsOrder": "sequence",
			"dependsOn": "tsc actions",
			"presentation": {
				"group": "actions",
			}
		},
	]
}
