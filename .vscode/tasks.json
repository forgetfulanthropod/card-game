{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Do everything",
            "dependsOn": ["tsc all", "esbuild all", "run server"],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "detail": "tsc + esbuild + node"
            // "runOptions": { "runOn": "folderOpen", }
        },
        {
            "label": "tsc all",
            // "type": "typescript",
            // "tsconfig": "./tsconfig.json",
            // "problemMatcher": "$tsc-watch",
            // "option": "watch",
            "type": "shell",
            "command": "./node_modules/.bin/tsc --build --watch server client shared game",
            "problemMatcher": ["$tsc-watch"],
            "group": "build",
            "detail": "check types on all files",
            "presentation": {
                "group": "group1"
            }
        },
        {
            "label": "esbuild all",
            "type": "shell",
            "command": "node scripts/buildAll.mjs watch",
            "detail": "build client + server",
            "presentation": {
                "group": "group1"
            }
        },
        {
            "label": "run server",
            "type": "shell",
            "group": "build",
            "command": "bash run server:server-watch-debug",
            "detail": "node builds/server/server.js"
        },
        {
            "label": "eslint all cached",
            "type": "shell",
            "command": "bash run lint",
            "problemMatcher": ["$eslint-stylish"],
            "detail": "node builds/server/server.js"
        }
    ]
}
