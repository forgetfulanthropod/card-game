{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Do everything",
            "dependsOn": [
                "tsc all",
                "esbuild all",
                "esbuild server",
                "run server"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "detail": "see https://stackoverflow.com/a/58181330"
            // "runOptions": { "runOn": "folderOpen", }
        },
        {
            "label": "tsc all",
            "type": "shell",
            "command": "tsc --build --watch server game shared client",
            "problemMatcher": ["$tsc-watch"],
            "group": "build"
        },
        {
            "label": "esbuild all",
            "type": "shell",
            "command": "node scripts/buildAll.mjs watch",
            "presentation": {
                "group": "builders",
                "clear": true
            }
        },
        {
            "label": "run server",
            "type": "shell",
            "command": "bash run server:server-watch"
        }
    ]
}
