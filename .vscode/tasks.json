{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Do everything",
            "dependsOn": ["tsc all", "esbuild all", "run server"],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "detail": "see https://stackoverflow.com/a/58181330"
            // "runOptions": { "runOn": "folderOpen", }
        },
        {
            "label": "tsc all",
            "type": "shell",
            "command": "./node_modules/.bin/tsc --build --watch server game shared client",
            "problemMatcher": ["$tsc-watch"],
            "group": "build",
            "presentation": {
                "group": "group1"
            }
        },
        {
            "label": "esbuild all",
            "type": "shell",
            "command": "node scripts/buildAll.mjs watch",
            "presentation": {
                "group": "group1"
            }
        },
        {
            "label": "run server",
            "type": "shell",
            "command": "bash run server:server-watch"
        }
    ]
}
