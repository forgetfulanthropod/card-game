{
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "gitlens.blame.ignoreWhitespace": true,
    "editor.tabSize": 4,
    "javascript.preferences.quoteStyle": "single",
    "typescript.preferences.quoteStyle": "single",
    "eslint.format.enable": true,
    "eslint.options": {
        "cache": true,
    },
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
        // "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "npm.packageManager": "pnpm",
    "files.exclude": {
        "**/.keep": true,
        "server/lib": true,
        "node_modules/": true,
        "server/node_modules/": true,
        "pnpm-lock.json": true,
        "server/pnpm-lock.json": true,
        "build/": true,
    },
    "prettier.tabWidth": 4,
    "editor.codeActionsOnSave": {
        // "source.organizeImports": true,
        "source.fixAll.eslint": true
    },
    "formatFiles.excludedFolders": [
        "node_modules",
        ".vscode",
        ".git",
        "dist",
        ".chrome",
        "build",
    ],
    "formatFiles.excludePattern": "**/*.json",
    "colorTabs.config": [
        {
            "regex": "client/.*",
            "color": "#000088",
            "label": "CLIENT"
        },
        {
            "regex": "shared/.*",
            "color": "#008800",
            "label": "SHARED"
        },
        {
            "regex": "actions/.*",
            "color": "#880000",
            "label": "SERVER"
        },
    ],
    "colorTabs.statusBarBackground": true,
    "colorTabs.tabBorder": true,
    "colorTabs.titleBackground": true,
    "colorTabs.activityBarBackground": false,
    "colorTabs.titleLabel": true,
    "eslint.packageManager": "pnpm",
    "workbench.colorCustomizations": {
        "activityBar.background": "#1C3314",
        "titleBar.activeBackground": "#27481C",
        "titleBar.activeForeground": "#F8FCF7"
    },
    "javascript.format.semicolons": "remove",
    "typescript.format.semicolons": "remove",
    "editor.formatOnSave": true,
}
