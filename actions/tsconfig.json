{
  "compilerOptions": {
    "module": "commonjs",
    // "module": "system",
    // "moduleResolution": "node",
    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "outDir": "lib",
    // "outFile": "lib/index.js",
    "sourceMap": true,
    "strict": false,
    "target": "es2017",
    "baseUrl": "..",
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./actions/src/*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
    },
  },
  "compileOnSave": true,
  "include": [
    "src",
    "../shared"
  ]
}
