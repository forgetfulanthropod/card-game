{
  "compilerOptions": {
    "module": "commonjs",
    "noEmit": true,
    "strict": true,
    "target": "es2017",
    "esModuleInterop": true,
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "@shared": [
        "../shared/index"
      ],
      "@/*": [
        "./*"
      ],
    },
  },
  "compileOnSave": true,
  "include": [
    "./**/*.ts",
    "../shared",
  ],
}
