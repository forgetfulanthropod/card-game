{
  "compilerOptions": {
    "module": "commonjs",
    // "module": "system",
    // "moduleResolution": "node",
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "outDir": "lib",
    // "outFile": "lib/index.js",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "esModuleInterop": true,
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
    },
  },
  "compileOnSave": true,
  "include": [
    ".",
    "../shared",
    "rulebook"
  ]
}
