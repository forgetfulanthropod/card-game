{
    "name": "actions-api",
    "description": "firebase cloud functions",
    "scripts": {
        "build": "rm -rf lib && tsc",
        "watch": "rm -rf lib && tsc -w",
        "justserve": "firebase emulators:start --only functions",
        "serve": "npm run build && npm run justserve",
        "watchserve": "npm run watch && npm run justserve",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log",
        "backend": "firebase emulators:start --only functions,firestore"
    },
    "engines": {
        "node": "14"
    },
    "main": "lib/actions/index.js",
    "dependencies": {
        "eventemitter3": "^4.0.7",
        "firebase": "^9.1.3",
        "firebase-admin": "^10.0.0",
        "firebase-functions": "^3.15.7"
    },
    "devDependencies": {
        "firebase-functions-test": "^0.3.3",
        "typescript": "^4.4.4"
    },
    "private": true
}
