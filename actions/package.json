{
    "name": "actions-api",
    "scripts": {
        "server-watch": "nodemon ../server-build/index.js",
        "server": "node ../server-build/index.js",
        "build": "esbuild index.ts --bundle --platform=node --keep-names --outfile=../server-build/index.js --sourcemap --allow-overwrite  --tsconfig=tsconfig.json",
        "watch": "npm run build -- --watch",
        "tsc": "tsc",
        "tsc-watch": "tsc-watch",
        "parcel": " npm run clear && parcel build",
        "pwatch": " npm run clear && parcel watch",
        "parcel-debug": "parcel build --no-optimize --no-scope-hoist --no-content-hash"
    },
    "engines": {
        "node": "14"
    },
    "source": "index.ts",
    "main": "lib/index.js",
    "dependencies": {
        "amd-loader": "^0.0.8",
        "baobab": "^2.6.1",
        "deep-diff": "^1.0.2",
        "eventemitter3": "^4.0.7",
        "express": "^4.17.1",
        "lodash": "^4.17.21",
        "socket.io": "^4.3.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.13",
        "typescript": "^4.4.4"
    },
    "private": true
}
