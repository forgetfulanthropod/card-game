{
    "name": "actions-api",
    "scripts": {
        "clear": "cp -r ../shared ./shared && rm -rf lib",
        "start": "npm run clear && tsc -w",
        "build": "npm run clear && tsc",
        "esbuild": "npm run clear && esbuild index.ts --bundle --minify --tree-shaking=ignore-annotations --platform=node --outfile=lib/index.js",
        "parcel": " npm run clear && parcel build",
        "pwatch": " npm run clear && parcel watch",
        "debug": " npm run clear && parcel build --no-optimize --no-scope-hoist --no-content-hash && node inspect lib/index.js",
        "minify": "uglifyjs lib/index.js > lib/uglyindex.js"
    },
    "engines": {
        "node": "14"
    },
    "source": "index.ts",
    "main": "lib/index.js",
    "dependencies": {
        "baobab": "^2.6.1",
        "deep-diff": "^1.0.2",
        "eventemitter3": "^4.0.7",
        "express": "^4.17.1",
        "lodash": "^4.17.21"
    },
    "devDependencies": {
        "@types/express": "^4.17.13",
        "typescript": "^4.4.4"
    },
    "private": true
}
