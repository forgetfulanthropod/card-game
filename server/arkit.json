{
    "$schema": "https://arkit.pro/schema.json",
    "components": [
        {
            "type": "Dependency",
            "patterns": ["node_modules/*"]
        },
        {
            "type": "Component",
            "patterns": ["**/*.ts"]
        }
    ],
    "excludePatterns": ["**/*.min.*"],
    "output": {
        "path": "arkit.svg",
        "groups": [
            {
                "type": "Battle",
                "patterns": ["gameState/battle/**"]
            },
            {
                "type": "Actions",
                "patterns": ["actions/**"]
            },
            {
                "type": "Rulebook",
                "patterns": ["rulebook/**"]
            },
            {
                "type": "Util",
                "patterns": ["util/**"]
            },
            {
                "type": "Dependencies",
                "components": ["Dependency"]
            },
            {
                "components": ["Component"]
            }
        ]
    }
}
