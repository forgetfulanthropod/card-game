// Server
{
    "compilerOptions": {
        "module": "commonjs",
        "incremental": true,
        "noEmit": true,
        "strict": true,
        "target": "es2017",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "paths": {
            "@serverActions": ["../game/actions/types/serverActions"],
            "@shared": ["../shared/index"],
            "@shared/code": ["../shared/code/index"],
            "@/*": ["../game/*"]
        }
    },
    "compileOnSave": true,
    "include": ["./**/*.ts", "../shared"]
}
