{
    "$schema": "https://arkit.pro/schema.json",
    "components": [
        {
            "type": "Dependency",
            "patterns": [
                "node_modules/*"
            ]
        },
        {
            "type": "Actions",
            "patterns": [
                "actions/**"
            ]
        },
        {
            "type": "GameState",
            "patterns": [
                "gameState/**"
            ]
        },
        {
            "type": "Rulebook",
            "patterns": [
                "rulebook/**"
            ]
        },
        {
            "type": "Util",
            "patterns": [
                "util"
            ]
        },
        {
            "type": "Component",
            "patterns": [
                "**/*.ts"
            ]
        }
    ],
    "excludePatterns": [
        "**/*.min.*"
    ],
    "output": {
        "path": "arkit.svg",
        "groups": [
            {
                "components": [
                    "Component",
                    "Actions",
                    "GameState",
                    "Rulebook",
                    "Util"
                ]
            }
        ]
    }
}
