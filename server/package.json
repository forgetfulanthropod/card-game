{
    "name": "kaiju-server",
    "scripts": {
        "server-watch": "nodemon --enable-source-maps --watch ../server-build/index.js ../server-build/index.js",
        "server": "node --enable-source-maps ../server-build/index.js",
        "server-watch-debug": "nodemon --inspect --enable-source-maps --watch ../server-build/index.js ../server-build/index.js",
        "build": "node ../scripts/serverEsbuild.mjs",
        "watch": "npm run build -- watch",
        "tsc": "tsc",
        "tsc-watch": "tsc -w"
    },
    "dependencies": {
        "axios": "^0.24.0",
        "baobab": "github:qpwo/baobab#more-detailed-types",
        "deep-diff": "^1.0.2",
        "express": "^4.17.1",
        "express-session": "^1.17.2",
        "lodash": "^4.17.21",
        "seedrandom": "^3.0.5",
        "socket.io": "^4.3.1",
        "winston": "^3.3.3"
    },
    "devDependencies": {
        "@types/express": "^4.17.13",
        "@types/express-session": "^1.17.4",
        "@types/lodash": "^4.14.176",
        "@types/seedrandom": "^3.0.1",
        "esbuild": "^0.13.9",
        "nodemon": "^2.0.14",
        "typescript": "^4.4.4"
    },
    "private": true
}
