{
    "name": "actions-api",
    "scripts": {
        "server-watch": "nodemon --enable-source-maps --watch ../server-build/index.js ../server-build/index.js",
        "server": "node --enable-source-maps ../server-build/index.js",
        "build": "node ../scripts/serverEsbuild.mjs",
        "watch": "npm run build -- watch",
        "tsc": "tsc",
        "tsc-watch": "tsc-watch",
        "parcel": " npm run clear && parcel build",
        "pwatch": " npm run clear && parcel watch",
        "parcel-debug": "parcel build --no-optimize --no-scope-hoist --no-content-hash"
    },
    "dependencies": {
        "baobab": "^2.6.1",
        "deep-diff": "^1.0.2",
        "express": "^4.17.1",
        "express-session": "^1.17.2",
        "lodash": "^4.17.21",
        "socket.io": "^4.3.1",
        "winston": "^3.3.3"
    },
    "devDependencies": {
        "@types/express": "^4.17.13",
        "@types/express-session": "^1.17.4",
        "@types/lodash": "^4.14.176",
        "esbuild": "^0.13.9",
        "typescript": "^4.4.4"
    },
    "private": true
}
